{
  "manifest_version": 3,
  "name": "Task Timer",
  "version": "1.0.0",
  "description": "Track time spent on tasks with simple start/stop timers.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Task Timer",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "alarms"]
}
